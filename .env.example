# Copy this file to .env.local and replace the placeholder values.

DATABASE_URL=postgres://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME
ANALYSIS_AI_PROVIDER=gemini
CATALOG_PROVIDER_ORDER=ebay,makeup_api
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_or_replit_ai_key
AI_INTEGRATIONS_GEMINI_BASE_URL=https://your-ai-base-url
OPENAI_API_KEY=your_openai_api_key
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
EVAL_MAX_FRAMES=10
EVAL_SKIP_AUDIO_TRANSCRIPTION=true
YOUTUBE_API_KEY=your_youtube_api_key
EXPO_PUBLIC_DOMAIN=localhost:5000
PORT=5000
REPLIT_DEV_DOMAIN=
REPLIT_DOMAINS=
